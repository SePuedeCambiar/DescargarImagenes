{
  "name": "descargarimagenes",
  "version": "1.0.0",
  "description": "Waifu Grabber Pro",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.waifu.grabber",
    "productName": "WaifuGrabber",
    "asar": true,
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".cache/puppeteer",
        "to": "puppeteer-browser",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "jimp": "^1.6.1",
    "puppeteer": "^22.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "electron": "^42.5.0",
    "electron-builder": "^24.13.3"
  }
}
